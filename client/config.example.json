    "advanced": {
        "collect_cpu": true,
        "collect_memory": true,
        "collect_disk": true,
        "collect_gpu": true,
        "collect_network": true,
        "collect_motherboard": true,
        "collect_bios": true,
        "compress_data": false
    }
}
